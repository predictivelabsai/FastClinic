# --- FastClinic Cockpit ---

# Admin login (override the defaults in production!)
FASTCLINIC_ADMIN_EMAIL=admin@fastclinic.example
FASTCLINIC_ADMIN_PASSWORD=FastClinic2026$
FASTCLINIC_SECRET=change-me-to-a-long-random-hex
FASTCLINIC_PORT=5005
FASTCLINIC_ENV_LABEL=FastClinic

# Path to the cockpit database (built by: python -m pms.importer)
# In Docker mount a volume and point here, e.g. /data/fastclinic.sqlite
FASTCLINIC_DB=

# Optional: pin the "today" reference date for due/lapsed maths (YYYY-MM-DD).
# Leave blank to use the latest activity date in the data.
FASTCLINIC_TODAY=

# AI assistant (free-form chat) — LangGraph agent with a configurable provider.
# Without a provider/key, slash-commands still work and chat shows a fallback.
#   MODEL_PROVIDER: xai | openai | anthropic | google
#   MODEL_NAME:     e.g. grok-4-1-fast-reasoning, gpt-4o-mini, claude-3-5-sonnet-latest
MODEL_PROVIDER=xai
MODEL_NAME=grok-4-1-fast-reasoning
XAI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# SEO audit module — site to audit
FASTCLINIC_SEO_SITE=https://fastclinic.example

# SMS providers (for outbound campaigns; optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
VOODOO_SMS_API_KEY=
VOODOO_SMS_FROM=

# Email provider (Postmark; optional)
POSTMARK_API_TOKEN=
POSTMARK_FROM=
EMAIL_REPLY_TO=
